# ─── Firebase Admin SDK ───────────────────────────────────────────────────────
# Obtenha em: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
# Cole a chave privada entre aspas. Substitua quebras de linha por \n
FIREBASE_ADMIN_PRIVATE_KEY=""

# ─── WhatsApp via Z-API ────────────────────────────────────────────────────────
# URL completa do endpoint send-text da sua instância Z-API
WHATSAPP_API_URL=https://api.z-api.io/instances/<INSTANCE_ID>/token/<TOKEN>/send-text
# Client-Token encontrado no painel Z-API (Security)
WHATSAPP_API_KEY=
# Número para alertas administrativos de novos leads (formato: 5511999990000)
WHATSAPP_RECIPIENT_PHONE=

# ─── Anthropic (IA) ───────────────────────────────────────────────────────────
# Obtenha em: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# ─── Autenticação ─────────────────────────────────────────────────────────────
# String aleatória longa e segura (mínimo 32 caracteres)
JWT_SECRET=

# ─── Webhook Meta Ads ─────────────────────────────────────────────────────────
# Token secreto configurado no painel do Meta para verificação do webhook
WEBHOOK_SECRET=
